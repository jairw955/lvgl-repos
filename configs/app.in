DEMO_SEL=${ext:-lv_demo}

export DEMO_CFG="-DLV_DRV_USE_SDL_GPU=y -DPC_SIMULATOR=y"
case $DEMO_SEL in
    lv_demo)
    export DEMO_CFG=$DEMO_CFG" -DLV_DEMO=y -DLVGL_DEMO_BENCHMARK=y"
    ;;
    fruit_ninja)
    export DEMO_CFG=$DEMO_CFG" -DFRUIT_NINJA=y"
    ;;
    ai_home)
    export DEMO_CFG=$DEMO_CFG" -DAI_HOME=y -DENABLE_ASR=y -DENABLE_TTS=y"
    ;;
    ai_home_ui)
    export DEMO_CFG=$DEMO_CFG" -DAI_HOME=y -DENABLE_ASR=n"
    ;;
esac
