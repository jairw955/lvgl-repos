#!/bin/bash
# Build helper functions for LVGL build scripts
# This file can be sourced by other scripts to use common functions

# 检查配置文件中是否启用了指定配置项
# 参数: $1 - 配置项名称 (如 BR2_PACKAGE_LVGL_DISABLE_THORVG)
# 返回: 0 如果配置启用(y), 1 如果未启用
check_config_enabled(){
    local config_name=$1
    # 如果 ROOT_PATH 未设置，尝试从调用者脚本的位置推断
    local root_path=${ROOT_PATH}
    if [ -z "$root_path" ]; then
        # 尝试从当前工作目录或脚本位置推断
        if [ -f ".config" ]; then
            root_path="$(pwd)"
        else
            root_path=$(dirname $(dirname $(realpath ${BASH_SOURCE[0]})))
        fi
    fi
    if [ -f "$root_path/.config" ]; then
        grep -q "^${config_name}=y$" "$root_path/.config"
        return $?
    fi
    return 1
}

# 如果配置启用，则添加编译选项到 FLAGS
# 参数: $1 - 配置项名称
#      $2 - 要添加的编译选项 (如 -DLV_CONF_BUILD_DISABLE_THORVG_INTERNAL=1)
# 注意: 需要在使用前设置 FLAGS 变量
add_flag_if_config(){
    local config_name=$1
    local flag=$2
    if check_config_enabled "$config_name"; then
        FLAGS="${FLAGS} ${flag}"
    fi
}

# 按 HOST + ARCH 追加 Buildroot 工具链的 CMake 参数（sysroot 与编译器）。
# HOST：工具链根目录（如 buildroot 的 output/host），末尾斜杠可有可无。
# ARCH：aarch64 → ${HOST}/aarch64-buildroot-linux-gnu/sysroot，${HOST}/bin/aarch64-buildroot-linux-gnu-gcc
#       arm     → ${HOST}/arm-buildroot-linux-gnueabihf/sysroot，${HOST}/bin/arm-buildroot-linux-gnueabihf-gcc
# 未同时设置 HOST 与 ARCH 时不追加，由 CMake 使用本机默认编译器。
# 参数：要追加的变量名，默认为 FLAGS（lvgl8/lvgl9 传入 LVGL_FLAGS）。
append_host_arch_cmake_flags(){
    local _varname="${1:-FLAGS}"
    declare -n _ref="$_varname"
    if [ -z "${HOST:-}" ] || [ -z "${ARCH:-}" ]; then
        return 0
    fi
    local host="${HOST%/}"
    local triple=""
    case "$ARCH" in
        aarch64) triple="aarch64-buildroot-linux-gnu" ;;
        arm)     triple="arm-buildroot-linux-gnueabihf" ;;
        *)
            echo "Error: unsupported ARCH='$ARCH' (expected aarch64 or arm)" >&2
            return 1
            ;;
    esac
    local sysroot="${host}/${triple}/sysroot"
    local prefix="${host}/bin/${triple}-"
    _ref="${_ref} -DCMAKE_SYSTEM_NAME=Linux -DCMAKE_SYSROOT=${sysroot}"
    _ref="${_ref} -DCMAKE_FIND_ROOT_PATH=${sysroot}"
    _ref="${_ref} -DCMAKE_FIND_ROOT_PATH_MODE_PROGRAM=NEVER"
    _ref="${_ref} -DCMAKE_FIND_ROOT_PATH_MODE_LIBRARY=BOTH"
    _ref="${_ref} -DCMAKE_FIND_ROOT_PATH_MODE_INCLUDE=BOTH"
    _ref="${_ref} -DCMAKE_C_COMPILER=${prefix}gcc -DCMAKE_CXX_COMPILER=${prefix}g++"
}
